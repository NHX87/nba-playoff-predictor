# Environment
.env
.venv/
venv/
.streamlit/secrets.toml

# Raw data — historical parquets are committed (never change, CI uses them directly)
# Only exclude current season (refreshed nightly) and any temp files
data/raw/*2025-26*.parquet
data/processed/*.duckdb
# Allow slim app DB for Streamlit Cloud deployment
!data/processed/nba_app.duckdb

# Binary model artifacts (regeneratable via pipeline)
models/trained/*.pkl
models/trained/*.joblib

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# IDE
.cursor/
.vscode/
